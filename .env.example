# Example .env for SmartOPD (do NOT commit secrets)

NODE_ENV=development
PORT=3000

# Postgres database
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# JWT
JWT_SECRET=your_jwt_secret

# Redis
REDIS_URL=redis://localhost:6379

# FHIR / ABDM endpoints
FHIR_BASE_URL=http://localhost:8080
ABDM_BASE_URL=http://localhost:8081

# Logging
LOG_LEVEL=info
