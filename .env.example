# ─── SmartOPD Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,https://app.smartopd.in
ENABLE_SWAGGER=true

# ─── Database (MySQL / MariaDB) ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=smartopd
DB_PASSWORD=your_db_password
DB_NAME=smartopd_db

# ─── JWT Authentication ───────────────────────────────────────────────────────
# REQUIRED: Use a 64+ char random string in production
JWT_SECRET=CHANGE_ME_use_a_64_char_random_string_here_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── SMS — MSG91 ──────────────────────────────────────────────────────────────
MSG91_API_KEY=
MSG91_SENDER_ID=SMTOPD
MSG91_OTP_TEMPLATE_ID=

# ─── Email — Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@smartopd.in

# ─── WhatsApp Business API (Meta) ─────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=

# ─── ABDM (ABHA / National Health Stack) ─────────────────────────────────────
# Sandbox: https://sandbox.abdm.gov.in | Production: https://abdm.gov.in
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_BASE_URL=https://dev.abdm.gov.in/gateway

# ─── NHCX (Health Claims Exchange) ───────────────────────────────────────────
NHCX_CLIENT_ID=
NHCX_CLIENT_SECRET=
NHCX_BASE_URL=https://dev.nhcx.abdm.gov.in

# ─── FHIR (R4) ───────────────────────────────────────────────────────────────
# Base URL for FHIR server (leave empty to skip remote publish)
FHIR_BASE_URL=
# Optional bearer token for external FHIR server
FHIR_AUTH_TOKEN=

# ─── Optional Integrations & Runtime Flags ───────────────────────────────────
# Use BullMQ instead of Bull (if set, code must be adapted)
USE_BULLMQ=false
# Sentry DSN for error reporting (optional)
SENTRY_DSN=

# ─── Lab Partners ─────────────────────────────────────────────────────────────
LAB_SRL_API_KEY=
LAB_THYROCARE_API_KEY=
LAB_DR_LAL_API_KEY=
LAB_METROPOLIS_API_KEY=

# ─── Drug Interaction Check ───────────────────────────────────────────────────
OPENFDA_API_KEY=

# ─── AWS (File Storage) ───────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=smartopd-uploads

# ─── Payment Gateway ──────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
